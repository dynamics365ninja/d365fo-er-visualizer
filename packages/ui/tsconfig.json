{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "noEmit": true,
    "paths": {
      "@er-visualizer/core": ["../core/src/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../core" }
  ]
}
